/**
 * whirlpool.c — CapStash NDK miner, optimized Whirlpool-512
 * v3.0
 *
 * Optimizations vs v2.0 (ported from CUDA miner):
 *   1. T0-only table + ROTL64: 2KB vs 16KB — fits in L1 cache
 *   2. Midstate: block 1 hashed once, reused every nonce (halves work)
 *   3. Partial target check: MSW first, >99.99% nonces rejected in 1 compare
 *   4. Direct uint64 block load — no byte-by-byte loop
 */

#include "whirlpool.h"
#include <string.h>
#include <android/log.h>

#define LOG_TAG "CapStash_Whirlpool"
#define LOGI(...) __android_log_print(ANDROID_LOG_INFO,  LOG_TAG, __VA_ARGS__)
#define LOGE(...) __android_log_print(ANDROID_LOG_ERROR, LOG_TAG, __VA_ARGS__)

// ── T0-only table (2KB) + RC (80 bytes) ──────────────────────────────────────
// Only T0 is used. T1..T7 are computed as ROTL64(T0[x], 8*k).
// This keeps the working set at 2KB — fits entirely in ARM L1 cache.
#include "whirlpool_tables.h"

// ── ROTL64 ────────────────────────────────────────────────────────────────────
static inline uint64_t rotl64(uint64_t x, int n) {
    return (x << n) | (x >> (64 - n));
}

// ── Extract byte n from uint64 ────────────────────────────────────────────────
#define BYTE(x, n) ((unsigned)(((x) >> (8 * (n))) & 0xFFu))

// ── Single round element using T0 + rotations ─────────────────────────────────
// Replaces 8 separate table lookups (T0..T7) with 1 lookup + 7 ROTL64 ops.
// ROTL64 is 1-2 cycles; table lookup from cold cache is 10+ cycles.
static inline uint64_t round_elt(
    uint64_t i0, uint64_t i1, uint64_t i2, uint64_t i3,
    uint64_t i4, uint64_t i5, uint64_t i6, uint64_t i7)
{
    return         T0[BYTE(i0, 0)]
         ^ rotl64(T0[BYTE(i1, 1)],  8)
         ^ rotl64(T0[BYTE(i2, 2)], 16)
         ^ rotl64(T0[BYTE(i3, 3)], 24)
         ^ rotl64(T0[BYTE(i4, 4)], 32)
         ^ rotl64(T0[BYTE(i5, 5)], 40)
         ^ rotl64(T0[BYTE(i6, 6)], 48)
         ^ rotl64(T0[BYTE(i7, 7)], 56);
}

// ── One full Whirlpool compression (Miyaguchi-Preneel) ────────────────────────
static void wp_compress(uint64_t state[8], const uint64_t data[8]) {
    uint64_t n[8], h[8], t[8];
    int i, r;

    for (i = 0; i < 8; i++) {
        h[i] = state[i];
        n[i] = data[i] ^ h[i];
    }

    for (r = 0; r < 10; r++) {
        // Key schedule
        t[0] = round_elt(h[0],h[7],h[6],h[5],h[4],h[3],h[2],h[1]) ^ RC[r];
        t[1] = round_elt(h[1],h[0],h[7],h[6],h[5],h[4],h[3],h[2]);
        t[2] = round_elt(h[2],h[1],h[0],h[7],h[6],h[5],h[4],h[3]);
        t[3] = round_elt(h[3],h[2],h[1],h[0],h[7],h[6],h[5],h[4]);
        t[4] = round_elt(h[4],h[3],h[2],h[1],h[0],h[7],h[6],h[5]);
        t[5] = round_elt(h[5],h[4],h[3],h[2],h[1],h[0],h[7],h[6]);
        t[6] = round_elt(h[6],h[5],h[4],h[3],h[2],h[1],h[0],h[7]);
        t[7] = round_elt(h[7],h[6],h[5],h[4],h[3],h[2],h[1],h[0]);
        for (i = 0; i < 8; i++) h[i] = t[i];

        // Data encryption
        t[0] = round_elt(n[0],n[7],n[6],n[5],n[4],n[3],n[2],n[1]) ^ h[0];
        t[1] = round_elt(n[1],n[0],n[7],n[6],n[5],n[4],n[3],n[2]) ^ h[1];
        t[2] = round_elt(n[2],n[1],n[0],n[7],n[6],n[5],n[4],n[3]) ^ h[2];
        t[3] = round_elt(n[3],n[2],n[1],n[0],n[7],n[6],n[5],n[4]) ^ h[3];
        t[4] = round_elt(n[4],n[3],n[2],n[1],n[0],n[7],n[6],n[5]) ^ h[4];
        t[5] = round_elt(n[5],n[4],n[3],n[2],n[1],n[0],n[7],n[6]) ^ h[5];
        t[6] = round_elt(n[6],n[5],n[4],n[3],n[2],n[1],n[0],n[7]) ^ h[6];
        t[7] = round_elt(n[7],n[6],n[5],n[4],n[3],n[2],n[1],n[0]) ^ h[7];
        for (i = 0; i < 8; i++) n[i] = t[i];
    }

    // Miyaguchi-Preneel
    for (i = 0; i < 8; i++) state[i] ^= n[i] ^ data[i];
}

// ── Specialized block2 compression ───────────────────────────────────────────
// Block 2 layout for 80-byte header:
//   data[0] = msg[8]  (tail0 — bytes 64-71, never changes per nonce batch)
//   data[1] = msg[9]  (tail1 — lower 32 bits = nBits, upper 32 = nonce)
//   data[2] = 0x0000000000000080  (padding byte)
//   data[3..6] = 0
//   data[7] = 0x8002000000000000  (640 bits BE length)
//
// Since data[3..6] are always zero, those XORs are skipped.
static void wp_compress_block2(uint64_t state[8],
                                uint64_t d0, uint64_t d1) {
    // Fixed block2 constants
    const uint64_t d2 = UINT64_C(0x0000000000000080);
    const uint64_t d7 = UINT64_C(0x8002000000000000);

    uint64_t n[8], h[8], t[8];
    int i, r;

    h[0] = state[0];  n[0] = d0 ^ h[0];
    h[1] = state[1];  n[1] = d1 ^ h[1];
    h[2] = state[2];  n[2] = d2 ^ h[2];
    h[3] = state[3];  n[3] = h[3];        // data[3]=0
    h[4] = state[4];  n[4] = h[4];        // data[4]=0
    h[5] = state[5];  n[5] = h[5];        // data[5]=0
    h[6] = state[6];  n[6] = h[6];        // data[6]=0
    h[7] = state[7];  n[7] = d7 ^ h[7];

    for (r = 0; r < 10; r++) {
        t[0] = round_elt(h[0],h[7],h[6],h[5],h[4],h[3],h[2],h[1]) ^ RC[r];
        t[1] = round_elt(h[1],h[0],h[7],h[6],h[5],h[4],h[3],h[2]);
        t[2] = round_elt(h[2],h[1],h[0],h[7],h[6],h[5],h[4],h[3]);
        t[3] = round_elt(h[3],h[2],h[1],h[0],h[7],h[6],h[5],h[4]);
        t[4] = round_elt(h[4],h[3],h[2],h[1],h[0],h[7],h[6],h[5]);
        t[5] = round_elt(h[5],h[4],h[3],h[2],h[1],h[0],h[7],h[6]);
        t[6] = round_elt(h[6],h[5],h[4],h[3],h[2],h[1],h[0],h[7]);
        t[7] = round_elt(h[7],h[6],h[5],h[4],h[3],h[2],h[1],h[0]);
        for (i = 0; i < 8; i++) h[i] = t[i];

        t[0] = round_elt(n[0],n[7],n[6],n[5],n[4],n[3],n[2],n[1]) ^ h[0];
        t[1] = round_elt(n[1],n[0],n[7],n[6],n[5],n[4],n[3],n[2]) ^ h[1];
        t[2] = round_elt(n[2],n[1],n[0],n[7],n[6],n[5],n[4],n[3]) ^ h[2];
        t[3] = round_elt(n[3],n[2],n[1],n[0],n[7],n[6],n[5],n[4]) ^ h[3];
        t[4] = round_elt(n[4],n[3],n[2],n[1],n[0],n[7],n[6],n[5]) ^ h[4];
        t[5] = round_elt(n[5],n[4],n[3],n[2],n[1],n[0],n[7],n[6]) ^ h[5];
        t[6] = round_elt(n[6],n[5],n[4],n[3],n[2],n[1],n[0],n[7]) ^ h[6];
        t[7] = round_elt(n[7],n[6],n[5],n[4],n[3],n[2],n[1],n[0]) ^ h[7];
        for (i = 0; i < 8; i++) n[i] = t[i];
    }

    // Miyaguchi-Preneel (skip zero data words)
    state[0] ^= n[0] ^ d0;
    state[1] ^= n[1] ^ d1;
    state[2] ^= n[2] ^ d2;
    state[3] ^= n[3];
    state[4] ^= n[4];
    state[5] ^= n[5];
    state[6] ^= n[6];
    state[7] ^= n[7] ^ d7;
}

// ── Load 80-byte header as 10 x uint64 (little-endian) ───────────────────────
static inline void load_msg(const uint8_t *header, uint64_t msg[10]) {
    int i, j;
    for (i = 0; i < 10; i++) {
        msg[i] = 0;
        for (j = 0; j < 8; j++)
            msg[i] |= (uint64_t)header[i * 8 + j] << (j * 8);
    }
}

// ── Midstate computation ──────────────────────────────────────────────────────
// Call once per new block template (not per nonce).
// Hashes block 1 (bytes 0-63 of the padded header) into midstate.
// Also extracts tail0 and tail1_base for use in the nonce loop.
void capstash_compute_midstate(const uint8_t *header,
                                uint64_t midstate[8],
                                uint64_t *tail0,
                                uint64_t *tail1_base) {
    uint64_t msg[10];
    load_msg(header, msg);

    memset(midstate, 0, 64);
    wp_compress(midstate, msg);  // block 1: bytes 0-63

    *tail0      = msg[8];
    // tail1_base: lower 32 bits = nBits (from header bytes 72-75)
    // upper 32 bits will be filled with nonce per iteration
    *tail1_base = msg[9] & UINT64_C(0x00000000FFFFFFFF);
}

// ── capstash_hash — full hash (used for verification / block submission) ──────
void capstash_hash(const uint8_t *header, uint8_t *out) {
    uint64_t msg[10];
    load_msg(header, msg);

    uint64_t state[8];
    memset(state, 0, 64);
    wp_compress(state, msg);  // block 1

    uint64_t b2[8];
    b2[0] = msg[8];
    b2[1] = msg[9];
    b2[2] = UINT64_C(0x0000000000000080);
    b2[3] = 0; b2[4] = 0; b2[5] = 0; b2[6] = 0;
    b2[7] = UINT64_C(0x8002000000000000);
    wp_compress(state, b2);  // block 2

    // XOR-fold 512 → 32 bytes
    for (int i = 0; i < 32; i++) {
        int wi  = i / 8, bi  = i % 8;
        int wi2 = (i + 32) / 8, bi2 = (i + 32) % 8;
        out[i] = (uint8_t)(((state[wi]  >> (bi  * 8)) & 0xff) ^
                           ((state[wi2] >> (bi2 * 8)) & 0xff));
    }
}

// ── capstash_hash_midstate — fast per-nonce hash using precomputed midstate ───
// Returns 1 if hash meets target (valid PoW), 0 otherwise.
// Uses partial target check: MSW first — rejects >99.99% of nonces in 1 op.
int capstash_hash_midstate(const uint64_t midstate[8],
                            uint64_t tail0,
                            uint64_t tail1_base,
                            uint32_t nonce,
                            const uint64_t target[4]) {
    uint64_t state[8];
    memcpy(state, midstate, 64);

    // Insert nonce into upper 32 bits of tail1
    uint64_t tail1 = tail1_base | ((uint64_t)nonce << 32);

    wp_compress_block2(state, tail0, tail1);

    // XOR-fold and partial target check (MSW = index 3, big-endian ordering)
    // target[3] = most significant 64-bit word of the 256-bit target
    uint64_t r3 = state[3] ^ state[7];
    if (r3 > target[3]) return 0;
    if (r3 < target[3]) return 1;

    uint64_t r2 = state[2] ^ state[6];
    if (r2 > target[2]) return 0;
    if (r2 < target[2]) return 1;

    uint64_t r1 = state[1] ^ state[5];
    if (r1 > target[1]) return 0;
    if (r1 < target[1]) return 1;

    uint64_t r0 = state[0] ^ state[4];
    return (r0 <= target[0]) ? 1 : 0;
}

int capstash_hash_meets_target(const uint8_t *hash, const uint8_t *target) {
    for (int i = 0; i < 32; i++) {
        if (hash[i] < target[i]) return 1;
        if (hash[i] > target[i]) return 0;
    }
    return 1;
}

// ── Hex helpers ───────────────────────────────────────────────────────────────
int hex_to_bytes(const char *hex, uint8_t *out, size_t out_len) {
    size_t hex_len = strlen(hex);
    if (hex_len % 2 != 0 || hex_len / 2 > out_len) return -1;
    for (size_t i = 0; i < hex_len / 2; i++) {
        unsigned int byte;
        if (sscanf(hex + i * 2, "%02x", &byte) != 1) return -1;
        out[i] = (uint8_t)byte;
    }
    return (int)(hex_len / 2);
}

void bytes_to_hex(const uint8_t *bytes, size_t len, char *out) {
    for (size_t i = 0; i < len; i++)
        sprintf(out + i * 2, "%02x", bytes[i]);
    out[len * 2] = '\0';
}